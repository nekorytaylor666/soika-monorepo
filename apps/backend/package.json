    "express": "^4.19.2",
    "hono": "^4.4.4",
    "pg": "^8.12.0",
    "postgres": "^3.4.4",
    "prisma": "^4.8.1",
    "superjson": "^2.2.1",
    "supertokens-node": "^18.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
